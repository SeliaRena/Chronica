QFrame#controlBar {
    background-color: #1b1b1b;
    border: none;
    border-radius: 12px;
}

QFrame#controlBarNavSection,
QFrame#controlBarControlSection {
    background-color: #0a0a0a;
    border: none;
    border-radius: 8px;
}

QFrame#controlBarNavButtons,
QFrame#controlBarControlButtons {
    background-color: transparent;
    border: none;
    border-radius: 8px;
}

QLabel#controlBarTitle {
    color: #4FD1C5;

    font-size: 22px;
    font-weight: 400;
    font-family: "Sora";
}