QFrame#trackingRecordSelector {
    background-color: #1b1b1b;
    border: none;
    border-radius: 10px;
}

QFrame#selectorRecordList {
    background-color: #0a0a0a;
    border: none;
    border-radius: 8px;
}

QListWidget#selectorListWidget {
    background-color: #111111;
    border: none;
    border-radius: 8px;
}

QListWidget#selectorListWidget::item {
    margin-top: 5px;
    margin-bottom: 5px;
}

QFrame#selectorListWrapper {
    background-color: #111111;
    border: none;
    border-radius: 8px;
}

QLabel#titleLabel {
    color: #4FD1C5;
}